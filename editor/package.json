{
  "name": "@rhobear/designs-editor",
  "version": "1.0.0",
  "description": "MIT-licensed visual website editor — GrapesJS core with RHOBEAR chrome",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "start": "vite preview --port 4173 --host",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "desktop:dev": "tauri dev",
    "package": "vite build && tauri build",
    "package:bin": "vite build && tauri build --no-bundle"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "grapesjs": "^0.22.6",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-custom-code": "^1.0.2",
    "grapesjs-plugin-forms": "^2.0.6",
    "grapesjs-preset-webpage": "^1.0.3",
    "jszip": "^3.10.1",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tauri-apps/cli": "^2",
    "vite": "^6.3.5"
  }
}