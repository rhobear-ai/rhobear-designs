{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RHOBEAR Designs",
  "version": "1.0.3",
  "identifier": "com.rhobear.designs",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rhobear-ai/rhobear-designs/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5QTczQTVCNTU2RUE0ClJXU2tibFZiT3FmcEFGTm5tK0hiOFpiaGQvb3ozTm5ZaTVpY0pST2wwYUxRUFpCQnI5UWNqWCt1Cg=="
    }
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "RHOBEAR Designs",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "RHOBEAR",
    "category": "Productivity",
    "shortDescription": "Offline visual website editor",
    "longDescription": "RHOBEAR Designs - a MIT-licensed visual website editor (GrapesJS core with RHOBEAR chrome) packaged as a desktop app that runs fully offline.",
    "copyright": "(c) RHOBEAR. MIT License.",
    "license": "MIT",
    "homepage": "https://rhobear.ai/designs",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": "artifact-signing-cli -e https://eus.codesigning.azure.net/ -a rhobear-signing -c rhobear-public %1",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}